# ========================================
# API Keys (REQUIRED)
# ========================================

# Anthropic API Key — used by all agents via LiteLlm
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Model name — e.g. claude-sonnet-4-5, claude-sonnet-4-6
LLM_MODEL_NAME=claude-sonnet-4-5


# ========================================
# Agent Ports (optional, defaults shown)
# ========================================

ORCHESTRATOR_PORT=9000
